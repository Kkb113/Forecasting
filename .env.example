# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Set to "development" or "production"
APP_ENV=development

# Required: any long random string. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# Development default: SQLite (no setup needed)
# DATABASE_URL=sqlite:///forecastiq_dev.db

# Production: Azure SQL connection string (uncomment and fill in for production)
# DATABASE_URL=mssql+pyodbc://username:password@server.database.windows.net/dbname?driver=ODBC+Driver+18+for+SQL+Server

# Storage backend: "local" for development, "azure" for production (Phase 5)
STORAGE_BACKEND=local

# Azure Blob Storage (Phase 5 only)
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_BLOB_CONTAINER=forecastiq-uploads

# Max upload size in MB (Phase 2+)
MAX_UPLOAD_MB=10
