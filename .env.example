# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── App environment ──────────────────────────────────────────────────────────
# "development" uses SQLite + local file storage (no extra setup needed).
# "production"  uses Azure SQL + /home/uploads on App Service.
APP_ENV=development

# Required: any long random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# ── Database ─────────────────────────────────────────────────────────────────

# Development default — SQLite, no setup needed:
# DATABASE_URL=sqlite:///forecastiq_dev.db

# Production — Azure SQL via pymssql (no ODBC driver required on App Service):
# DATABASE_URL=mssql+pymssql://forecast:YOUR_PASSWORD@forecastlogic.database.windows.net:1433/free-sql-db-0224916?charset=utf8

# ── Upload storage ───────────────────────────────────────────────────────────

# Development: relative uploads/ folder next to the project root (auto-created).
# Production:  /home/uploads on Azure App Service (/home is the persistent volume).
# UPLOAD_FOLDER=/home/uploads

# Max upload size in MB
MAX_UPLOAD_MB=10
